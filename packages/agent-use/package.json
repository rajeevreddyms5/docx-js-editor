{
  "name": "@eigenpal/docx-editor-agents",
  "version": "0.0.28",
  "description": "Agent-friendly API for DOCX document review — read, comment, propose changes, accept/reject tracked changes",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.mjs",
      "require": "./dist/bridge.js"
    }
  },
  "typesVersions": {
    "*": {
      "bridge": [
        "./dist/bridge.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eigenpal/docx-core": "workspace:*"
  },
  "keywords": [
    "docx",
    "ai",
    "agent",
    "review",
    "track-changes",
    "comments",
    "legal",
    "contract"
  ],
  "author": "EigenPal",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/eigenpal/docx-js-editor.git",
    "directory": "packages/agent-use"
  },
  "publishConfig": {
    "access": "public"
  }
}
